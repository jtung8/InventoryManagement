# Terraform local directories
.terraform/

# State files (contain resource IDs and potentially sensitive data)
*.tfstate
*.tfstate.backup

# Variable override files (may contain secrets)
*.tfvars
!*.tfvars.example

# Crash logs
crash.log

# Override files (used for local-only overrides, not committed)
override.tf
override.tf.json
*_override.tf
*_override.tf.json
